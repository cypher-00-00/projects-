#include <iostream>
#include<thread>
using namespace std;

int main() {
    int balance = 456;
    string user = "Aman";
    string username = "";
    int password = 3678;
    bool flag = true;

    // Username Verification Loop
    while (flag) {
        cout << "Enter username: ";
        cin >> username;

        if (user != username) {
            string res;
            cout << "Invalid username. Do you wanna continue? (yes/no): ";
            cin >> res;
            if (res == "no" || res == "NO") {
                return 0; // Exit program entirely if they want to stop
            }
        } else {
            break; // Username matches, proceed
        }
    }

    // Password Verification
    int password_user;
    cout << "Password: ";
    cin >> password_user; // Fixed variable target
    
    if (password_user != password) {
        cout << "\nWrong password. Exiting..." << endl;
        return 0;
    }

    // ATM Menu Loop
    bool login = true;
    while (login) {
        cout << "\n--- ATM MENU ---" << endl;
        cout << "1. Balance check" << endl;
        cout << "2. Withdraw" << endl;
        cout << "3. Deposit" << endl;
        cout << "4. Exit" << endl;
        cout << "Enter choice: ";

        int choice;
        cin >> choice;
        
        switch (choice) {
            case 1:
                cout << "Your current balance is: " << balance << endl; // Fixed string output
                break;

            case 2:
                cout << "Your current balance is: " << balance << endl;
                cout << "Enter amount to withdraw: ";
                int withdraw_amount;
                cin >> withdraw_amount;
                
                if (balance >= withdraw_amount) {
                    balance -= withdraw_amount;
                    cout << "Withdrawal successful!" << endl;
                } else {
                    this_thread::sleep_for(chrono::milliseconds(1000));
                    cout << "You don't have sufficient balance!" << endl; // Added missing cout
                }
                cout << "Your current balance is: " << balance << endl;
                break; // Ensure clean break

            case 3:
                cout << "Your current balance is: " << balance << endl;
                cout << "Enter amount to deposit: ";
                int deposit_amount;
                cin >> deposit_amount;
                
                balance += deposit_amount;
                cout << "Deposit successful!" << endl;
                cout << "Your current balance is: " << balance << endl;
                break; // Added missing break to prevent falling into case 4

            case 4:
                cout << "You logged out successfully." << endl;
                login = false;
                break;

            default:
                cout << "Wrong input! Please select a valid option." << endl;
                break;
        }
    }
    return 0;
}
